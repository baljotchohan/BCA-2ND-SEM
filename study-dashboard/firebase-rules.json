{
  "rules": {
    "onlineUsers": {
      ".read": true,
      ".write": true,
      ".indexOn": ["name"],
      "$user_id": {
        ".validate": "newData.hasChildren(['name', 'joinedAt', 'status'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "status": {
          ".validate": "newData.val() == 'active' || newData.val() == 'idle'"
        },
        "joinedAt": {
          ".validate": "newData.isNumber()"
        },
        "examStarted": {
          ".validate": "newData.isBoolean()"
        }
      }
    }
  }
}
