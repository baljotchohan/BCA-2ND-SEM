{
  "rules": {
    "onlineUsers": {
      ".read": true,
      ".write": true,
      ".indexOn": ["name", "status", "lastSeen", "totalStudyTime"],
      "globalChat": {
        ".validate": true
      },
      "$user_id": {
        ".validate": "newData.hasChildren(['name', 'status'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "status": {
          ".validate": "newData.val() == 'active' || newData.val() == 'idle' || newData.val() == 'offline'"
        },
        "joinedAt": {
          ".validate": "newData.isNumber()"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        },
        "totalStudyTime": {
          ".validate": "newData.isNumber()"
        },
        "totalVisits": {
          ".validate": "newData.isNumber()"
        },
        "examStarted": {
          ".validate": "newData.isBoolean()"
        },
        "isHidden": {
          ".validate": "newData.isBoolean()"
        },
        "history": {
          "$entry": {
            ".validate": "newData.hasChildren(['action', 'timestamp'])"
          }
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      }
    }
  }
}
